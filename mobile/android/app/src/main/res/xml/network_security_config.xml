<?xml version="1.0" encoding="utf-8"?>
<!-- Dev-friendly HTTP to local API. Tighten for production (HTTPS + pinning). -->
<network-security-config>
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
